#%Module1.0#####################################################################
##
## boltz modulefile
##
proc ModulesHelp { } {
        global version prefix

        puts stderr "\tboltz- Adds boltz to your path"
}

module-whatis	"boltz-2.2.1"

set      hpcc_modules    $::env(HPCC_MODULES)

if { [module-info mode load] || [module-info mode switch2] } {
    puts stdout "module load miniconda3; conda config --set env_prompt '(\$(echo {default_env} |  perl -p -e \"s#.+pkgs/##\")) '; conda activate ${hpcc_modules}/boltz/2.2.1/env;"
} elseif { [module-info mode remove] && ![module-info mode switch3] } {
    puts stdout "conda deactivate;"
}
setenv BOLTZ_CACHE /srv/projects/db/boltz
