#%Module1.0#####################################################################
##
## rstudio modulefile
##
proc ModulesHelp { } {
        global version prefix

        puts stderr "\t - Adds rstudio-server to your path"
}

module-whatis   "rstudio-server-2026.04.0-526"

set      hpcc_modules    $::env(HPCC_MODULES)

prepend-path     PATH             ${hpcc_modules}/rstudio-server/2026.04.0-526/bin

