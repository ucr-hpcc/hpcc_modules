#%Module1.0#####################################################################
##
## socat modulefile
##
proc ModulesHelp { } {
        global version prefix

        puts stderr "\tsocat - Adds socat (multipurpose relay for bidirectional data transfer) to your path"
}

module-whatis	"socat-1.8.1.3"

set      hpcc_modules    $::env(HPCC_MODULES)

prepend-path    PATH            ${hpcc_modules}/socat/1.8.1.3/bin
prepend-path    MANPATH         ${hpcc_modules}/socat/1.8.1.3/share/man
