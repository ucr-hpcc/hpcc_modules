#%Module1.0#####################################################################
##
## exfat modulefile
##
proc ModulesHelp { } {
        global version prefix

        puts stderr "\texfat - Adds fuse-exfat and exfat-utils to your path"
}

module-whatis   "exfat-1.4.0"

set      hpcc_modules    $::env(HPCC_MODULES)

prepend-path    PATH             ${hpcc_modules}/exfat/1.4.0/sbin
prepend-path    MANPATH          ${hpcc_modules}/exfat/1.4.0/share/man
