#%Module1.0#####################################################################
##
## cramino modulefile
##
proc ModulesHelp { } {
        global version prefix
        puts stderr "\tcramino - Adds cramino to your path"
}

module-whatis   "cramino-1.4.0"

set      hpcc_modules    $::env(HPCC_MODULES)

prepend-path    PATH            ${hpcc_modules}/cramino/1.4.0/bin
