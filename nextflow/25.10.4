#%Module1.0#####################################################################
##
## nextflow modulefile
##
proc ModulesHelp { } {
        global version prefix

        puts stderr "\tnextflow - Adds nextflow to your path"
}

module-whatis	"nextflow-25.10.4"

set      hpcc_modules    $::env(HPCC_MODULES)

module load java
module load singularity
prepend-path    PATH            ${hpcc_modules}/nextflow/bin
setenv          NXF_VER         25.10.4

