#%Module1.0#####################################################################
##
## Qt modulefile
##
proc ModulesHelp { } {
        global version prefix

        puts stderr "\tQt - Adds Qt 6.11.1 to your path"
}

module-whatis   "Qt-6.11.1"

set      hpcc_modules    $::env(HPCC_MODULES)

setenv           QTDIR               ${hpcc_modules}/qt/6.11.1
setenv           QT_DIR              ${hpcc_modules}/qt/6.11.1

prepend-path     PATH                ${hpcc_modules}/qt/6.11.1/bin
prepend-path     CPLUS_INCLUDE_PATH  ${hpcc_modules}/qt/6.11.1/include
prepend-path     LIBRARY_PATH        ${hpcc_modules}/qt/6.11.1/lib
prepend-path     LD_LIBRARY_PATH     ${hpcc_modules}/qt/6.11.1/lib
prepend-path     PKG_CONFIG_PATH     ${hpcc_modules}/qt/6.11.1/lib/pkgconfig
prepend-path     MANPATH             ${hpcc_modules}/qt/6.11.1/share/man
