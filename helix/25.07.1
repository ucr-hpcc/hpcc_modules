#%Module1.0#####################################################################
##
## Helix modulefile
##
proc ModulesHelp { } {
        global version prefix

        puts stderr "\t - Adds Helix to your path"
}

module-whatis   "Helix-25.07.1"

set      hpcc_modules    $::env(HPCC_MODULES)

# Setup PATHs
prepend-path    PATH            ${hpcc_modules}/helix/25.07.1/bin

setenv HELIX_RUNTIME ${hpcc_modules}/helix/25.07.1/runtime
