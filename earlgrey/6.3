#%Module1.0#####################################################################
##
## earlgrey modulefile
##
proc ModulesHelp { } {
        puts stderr "\tearlGrey 6.3.3 - RepeatAnnotation and classification pipeline"
        puts stderr "\thttps://github.com/TobyBaril/EarlGrey"
}

module-whatis	"earlgrey-6.3.3"

# only one earlgrey version at a time
conflict earlgrey

set      hpcc_modules    $::env(HPCC_MODULES)

# Get user
set      user            [module-info username]

if { [module-info mode load] || [module-info mode switch2] } {
    puts stdout "module load miniconda3; conda config --set env_prompt '(\$(echo -n {default_env} | perl -p -e \"s#.+pkgs/##; s#/env##\")) '; conda activate --stack ${hpcc_modules}/earlgrey/6.3;"
} elseif { [module-info mode remove] && ![module-info mode switch3] } {
    puts stdout "conda config --set env_prompt '({default_env}) '; conda deactivate;"
}

