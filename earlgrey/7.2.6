#%Module1.0#####################################################################
##
## earlGrey modulefile
##
proc ModulesHelp { } {
        global proj_version

        puts stderr "\tearlGrey ${proj_version} - RepeatAnnotation and classification pipeline"
        puts stderr "\thttps://github.com/TobyBaril/EarlGrey"
}

module-whatis	"earlgrey-7.2.6"

# only one earlgrey version at a time
conflict earlgrey

# pixi provides the runtime; auto_handling is on, so this auto-loads/unloads it
prereq pixi

set     hpcc_modules    $::env(HPCC_MODULES)
set 	pixi_env "${hpcc_modules}/earlgrey/7.2.6/env"
set 	pixi_root "${hpcc_modules}/earlgrey/7.2.6/EarlGrey/pixi"
set	pixi_name "earlgrey"
set	proj_version "7.2.6"

setenv PIXI_PROJECT_NAME "${pixi_name}"
setenv PIXI_PROJECT_VERSION ${proj_version}
setenv PIXI_PROJECT_MANIFEST "${pixi_root}/pixi.toml"
setenv CONDA_DEFAULT_ENV "${pixi_name}/${proj_version}"
prepend-path PERL5LIB "${pixi_env}/share/RepeatMasker"
prepend-path PERL5LIB "${pixi_env}/share/RepeatModeler"

setenv PIXI_PROMPT "${pixi_name}/${proj_version}"
prepend-path PATH "${pixi_env}/bin"
prepend-path LD_LIBRARY_PATH "${pixi_env}/lib"
setenv CONDA_PREFIX "${pixi_env}"
setenv PIXI_PROJECT_ROOT "${pixi_root}"

