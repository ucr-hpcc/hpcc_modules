#%Module1.0#####################################################################
##
## picrust2 modulefile
##
proc ModulesHelp { } {
        global version prefix

        puts stderr "\tpicrust2 - Adds picrust2 to your path"
}

module-whatis	"picrust2-2.6.3"

set      hpcc_modules    $::env(HPCC_MODULES)

if { [module-info mode load] || [module-info mode switch2] } {
    puts stdout "module load miniconda3; conda config --set env_prompt '(\$(dirname {default_env} |  perl -p -e \"s#.+pkgs/##; s#/env##\")) '; conda activate --stack ${hpcc_modules}/picrust2/2.6.3/env;"
} elseif { [module-info mode remove] && ![module-info mode switch3] } {
    puts stdout "conda deactivate;"
}

