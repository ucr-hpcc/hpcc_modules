#%Module1.0#####################################################################
##
## BBTools modulefile
##
proc ModulesHelp { } {
        global version prefix

        puts stderr "\t - Adds BBTools (BBMap) to your path"
}

module-whatis   "BBTools-39.81"

set      hpcc_modules    $::env(HPCC_MODULES)

module load java

# Setup PATHs
prepend-path    PATH            ${hpcc_modules}/BBTools/39.81/bin
