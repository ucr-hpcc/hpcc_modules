#%Module1.0#####################################################################
##
## transcriptclean modulefile
##
proc ModulesHelp { } {
        global version prefix

        puts stderr "\ttranscriptclean- Adds transcriptclean to your path"
}

module-whatis	"transcriptclean-2.1"

set      hpcc_modules    $::env(HPCC_MODULES)
module load miniconda3
if { [module-info mode load] || [module-info mode switch2] } {
    puts stdout "module load miniconda3; conda config --set env_prompt '(\$(echo {default_env} |  perl -p -e \"s#.+pkgs/##\")) '; conda activate ${hpcc_modules}/transcriptclean/2.1/env;"
} elseif { [module-info mode remove] && ![module-info mode switch3] } {
    puts stdout "conda deactivate;"
}
