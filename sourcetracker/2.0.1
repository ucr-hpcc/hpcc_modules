#%Module1.0#####################################################################
##
## sourcetracker modulefile
##
proc ModulesHelp { } {
        global version prefix

        puts stderr "\tsourcetracker - Adds sourcetracker to your path"
}

module-whatis	"sourcetracker-2.0.1"

set      hpcc_modules    $::env(HPCC_MODULES)

if { [module-info mode load] || [module-info mode switch2] } {
    puts stdout "module load miniconda3; conda config --set env_prompt '(\$(dirname {default_env} |  perl -p -e \"s#.+pkgs/##; s#/env##\")) '; conda activate --stack ${hpcc_modules}/sourcetracker/2.0.1/env;"
} elseif { [module-info mode remove] && ![module-info mode switch3] } {
    puts stdout "conda deactivate;"
}

