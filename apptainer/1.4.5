#%Module1.0#####################################################################
##
## apptainer modulefile
##
proc ModulesHelp { } {
        global version prefix

        puts stderr "\tapptainer - Adds apptainer to your path"
}

module-whatis   "apptianer-1.4.5"

set      hpcc_modules    $::env(HPCC_MODULES)

module load libseccomp fuse squashfuse gocryptfs
setenv          APPTAINER_BINDPATH    /bigdata
prepend-path    PATH                    ${hpcc_modules}/apptainer/1.4.5/bin
